{
  "trailingSlash": true,
  "redirects": [
    { "source": "/tongeren/", "destination": "/workflow-automatisering/", "statusCode": 301 },
    { "source": "/lanaken/", "destination": "/website-laten-maken/", "statusCode": 301 },
    { "source": "/werkwijze/", "destination": "/over-ons/", "statusCode": 301 },
    { "source": "/belgie/", "destination": "/limburg/", "statusCode": 301 },
    { "source": "/diensten/website-laten-maken/", "destination": "/website-laten-maken/", "statusCode": 301 },
    { "source": "/diensten/workflow-automatisering/", "destination": "/workflow-automatisering/", "statusCode": 301 },
    { "source": "/diensten/ai-implementatie/", "destination": "/ai-implementatie/", "statusCode": 301 },
    { "source": "/diensten/geo-aeo/", "destination": "/geo-aeo/", "statusCode": 301 },
    { "source": "/diensten/seo/", "destination": "/geo-aeo/", "statusCode": 301 },
    { "source": "/pakketten/", "destination": "/contact/", "statusCode": 301 },
    { "source": "/blog/wat-is-geo-aeo/", "destination": "/blog/wat-is-generative-engine-optimization/", "statusCode": 301 },
    { "source": "/privacy/", "destination": "/privacybeleid/", "statusCode": 301 },
    { "source": "/voorwaarden/", "destination": "/algemene-voorwaarden/", "statusCode": 301 }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=(), browsing-topics=()" },
        { "key": "Strict-Transport-Security", "value": "max-age=31536000; includeSubDomains" },
        { "key": "Content-Security-Policy", "value": "default-src 'self'; base-uri 'self'; object-src 'none'; img-src 'self' data:; style-src 'self' 'unsafe-inline'; font-src 'self'; script-src 'self' 'sha256-/x7W7R75k8Roq0WaVRQX9blP4OufE5xbAdzklGxsgpw='; form-action 'self' https://formspree.io; connect-src 'self' https://formspree.io; frame-ancestors 'none'" }
      ]
    },
    {
      "source": "/fonts/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=2592000, stale-while-revalidate=604800" }
      ]
    },
    {
      "source": "/(.*)\\.(jpg|jpeg|png|svg|ico|webp)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400, stale-while-revalidate=604800" }
      ]
    },
    {
      "source": "/(.*)\\.(css|js)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600, stale-while-revalidate=86400" }
      ]
    }
  ]
}
